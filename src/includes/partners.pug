.partners
  .container-ins   
    h2.title Нам доверяют
    .swiper-container.partners-js
      .swiper-wrapper
        mixin partner(img)
          .swiper-slide 
            .partners__item 
              img(src="assets/img/partner"+img+".webp", alt="")
        +partner(1)
        +partner(2)
        +partner(3)
        +partner(4)
        +partner(5)
      .swiper-pagination
